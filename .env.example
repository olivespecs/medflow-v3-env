# Required by hackathon inference.py (LLM mode)
API_BASE_URL=https://router.huggingface.co/v1
# MODEL_NAME has a default in inference.py; override to target a different model.
MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct
HF_TOKEN=your-hf-token
# Optional aliases accepted by inference.py when HF_TOKEN is unset:
# API_KEY=your-hf-token
# OPENAI_API_KEY=your-hf-token

# Optional - if you use from_docker_image()
# LOCAL_IMAGE_NAME=your-local-image

# Optional: 1 enables inference diagnostics on stderr (stdout stays START/STEP/END).
INFERENCE_VERBOSE=0

# Optional: OpenEnv API endpoint for inference.py
OPENENV_BASE_URL=http://localhost:7860

# --- API authentication (recommended for any shared deployment) ---
# Requests to protected endpoints must include either:
#   X-API-Key: <OPENENV_API_KEY>
# or
#   Authorization: Bearer <OPENENV_API_KEY>
# OPENENV_REQUIRE_API_KEY=1 enforces auth and returns 503 if OPENENV_API_KEY is missing.
# OPENENV_REQUIRE_API_KEY=0 leaves auth optional when OPENENV_API_KEY is unset
# (useful for public Hugging Face Spaces demos).
OPENENV_REQUIRE_API_KEY=0
# OPENENV_API_KEY=change-me-to-a-strong-random-value

# Trust proxy headers only when running behind a known reverse proxy.
# 0 = ignore X-Forwarded-For from clients
# 1 = trust X-Forwarded-For only when request comes from TRUSTED_PROXY_IPS
TRUST_PROXY_HEADERS=0
# Comma-separated proxy IPs/CIDRs (used only when TRUST_PROXY_HEADERS=1)
# TRUSTED_PROXY_IPS=10.0.0.0/8,192.168.0.0/16

# CORS: Comma-separated list of allowed origins (defaults to localhost:7860 if unset)
# In production (OPENENV_ENV=production), this must be set and cannot contain '*'.
# CORS_ORIGINS=http://localhost:7860,http://127.0.0.1:7860,https://your-app.example.com
OPENENV_ENV=development

# --- Rate limiting (defaults shown) ---
# Lower on resource-constrained deployments; raise for load-testing setups.
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
# Remove inactive IP entries from rate-limit stores after this TTL (seconds)
RATE_LIMIT_ENTRY_TTL_SECONDS=86400

# --- Advanced features (safe defaults for 2 vCPU / 8GB / no GPU) ---
# Copying this file to .env should NOT trigger large model downloads or long CPU runs.
# Set to 1 on GPU or high-RAM machines (e.g. Google Colab); see README Colab section.

# BERTScore in Task 4 grader (downloads models; slow on CPU)
ENABLE_BERT_SCORE=0
# Optional: local metric path / id for evaluate.load()
# BERTSCORE_METRIC_PATH=bertscore
# Optional: model id or local model directory path for BERTScore
# BERTSCORE_MODEL_TYPE=distilbert-base-uncased
# Set to 1 to fail fast instead of downloading from the internet
# BERTSCORE_LOCAL_FILES_ONLY=0

# Hugging Face transformer NER in hybrid baseline (~1.3GB model download; slow on CPU)
USE_TRANSFORMERS_NER=0

# --- NER confidence thresholds (defaults shown; tune if NER over/under-redacts) ---
# Base threshold for standard PHI passes (0.4 = balanced sensitivity/specificity)
NER_CONFIDENCE_THRESHOLD=0.4
# Final safety-net pass after rule-based redaction — higher bar avoids false positives
NER_CONFIDENCE_THRESHOLD_FINAL=0.6
# Adversarial identifier scrubbing in Task 3 — lower bar to catch rare-disease/ZIP combos
NER_CONFIDENCE_THRESHOLD_ADVERSARIAL=0.3
