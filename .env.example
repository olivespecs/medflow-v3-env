# ============================================================
# Required by hackathon inference.py (LLM mode)
# ============================================================
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct
HF_TOKEN=your-hf-token-here

# Optional aliases accepted by inference.py
# API_KEY=your-hf-token
# OPENAI_API_KEY=your-hf-token

# ============================================================
# Environment server
# ============================================================
OPENENV_BASE_URL=http://localhost:7860

# ============================================================
# API authentication (optional — for shared deployments)
# ============================================================
OPENENV_REQUIRE_API_KEY=0
# OPENENV_API_KEY=change-me-to-a-strong-random-value

# ============================================================
# Runtime configuration
# ============================================================
OPENENV_ENV=development
INFERENCE_VERBOSE=0

# CORS origins (comma-separated)
# CORS_ORIGINS=http://localhost:7860,http://127.0.0.1:7860

# ============================================================
# Rate limiting (defaults shown)
# ============================================================
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_ENTRY_TTL_SECONDS=86400

# ============================================================
# ML features (safe defaults for 2 vCPU / 8GB / no GPU)
# ============================================================
USE_TRANSFORMERS_NER=0
ENABLE_BERT_SCORE=0
NER_CONFIDENCE_THRESHOLD=0.4
NER_CONFIDENCE_THRESHOLD_FINAL=0.6
NER_CONFIDENCE_THRESHOLD_ADVERSARIAL=0.3

# ============================================================
# Proxy configuration
# ============================================================
TRUST_PROXY_HEADERS=0
# TRUSTED_PROXY_IPS=10.0.0.0/8,192.168.0.0/16
